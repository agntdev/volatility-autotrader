[
  {
    "name": "/history empty state invites next step",
    "steps": [
      {
        "send": { "text": "/history" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "No trades yet — enable autotrading or run a scan to open one."
            }
          }
        ]
      }
    ]
  },
  {
    "name": "History menu button shows empty state",
    "steps": [
      {
        "send": { "callback": "history:show" },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "editMessageText",
            "payload": {
              "text": "No trades yet — enable autotrading or run a scan to open one."
            }
          }
        ]
      }
    ]
  }
]
